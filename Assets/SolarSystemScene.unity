  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 31629047cadc70941a4f1725fe6382fe, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CelestialBody
  bodyName: Earth
  labelColor: {r: 0, g: 0.0627451, b: 1, a: 1}
  profileImage: {fileID: 21300000, guid: b315536a305ecc747a1907efcb50cbe0, type: 3}
  profileDescription: <b>Earth, the third planet from the Sun</b>, is the only known
    world that supports life. Its surface is dominated by vast oceans, diverse ecosystems,
    and a complex atmosphere that together create a hospitable environment.\n\nKnown
    as the <b>Blue Planet</b> for its abundance of water, Earth is a unique and vibrant
    world where geological and atmospheric processes sustain its biosphere.
  stats:
  - label: Mass
    value: <b>5.97 x 10<sup>24</sup>kg</b>
  - label: Diameter
    value: <b>12,756 km</b>
  - label: Distance to Sun
    value: <b>150 million km</b>
  - label: Orbital Period
    value: <b>365.2 days</b>
  - label: Length of Day
    value: <b>24 hours</b>
  - label: Gravity
    value: <b>9.80 m/s<sup>2</sup></b>
  - label: Satellite count
    value: 1
  - label: Temperature (mean)
    value: "<b>15 \xB0C</b>"
  - label: Atmosphere
    value: N2+O2
  orbitCharacteristicsDescription: <b>Earth orbits the Sun</b> at an average distance
    of approximately 149.6 million kilometers (93 million miles), within a region
    known as the habitable zone, where temperatures allow liquid water to exist.
    Earth completes one orbit in 365.25 days, with this extra quarter-day leading
    to leap years every four years to maintain our calendar.\n\nThe planet's 24-hour
    rotation on its axis creates the day-night cycle, and its 23.5-degree axial tilt
    results in seasonal changes as sunlight varies across different latitudes over
    the year.
  structureDescription: "<b>Earth has a dynamic internal structure</b>, beginning
    with a solid inner core composed of iron and nickel, with temperatures reaching
    5,400\xB0C (9,800\xB0F).\\n\\nSurrounding the inner core is a liquid outer core,
    also made of iron and nickel, whose movement generates Earth's magnetic field.\\n\\nAbove
    the core lies the silicate mantle, which is divided into upper and lower regions
    and drives plate tectonics through convection currents.\\n\\nEarth's outermost
    layer, the crust, varies in thickness from 5 kilometers (3 miles) in the oceanic
    regions to 70 kilometers (43 miles) in mountainous areas, supporting a diverse
    range of geological and biological activity."
  atmosphereImage: {fileID: 21300000, guid: 9e3aab7bd613e8d498f46943543b841d, type: 3}
  atmosphereDescription: <b>Earth's atmosphere is a vital</b>, multi-layered system
    that supports life, regulates temperature, and drives weather patterns.\n\nComposed
    mainly of nitrogen (78%) and oxygen (21%), with traces of carbon dioxide, water
    vapor, and other gasses, this protective layer shields the surface from harmful
    ultraviolet radiation.\n\nDivided into layers-troposphere, stratosphere, mesosphere,
    thermosphere, and exosphere-Earth's atmosphere is responsible for the greenhouse
    effect, which keeps the planet warm enough to sustain liquid water and life.
  focusDistanceOverride: 0
  minFocusDistanceOverride: 0
  maxFocusDistanceOverride: 30
  galleryEntries: []
