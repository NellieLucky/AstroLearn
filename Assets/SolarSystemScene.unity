  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CelestialBody
  bodyName: Moon
  profileImage: {fileID: 21300000, guid: d568d86991c861e4485a1b40b1c51fca, type: 3}
  profileDescription: <b>The Moon, Earth's only natural satellite</b>, is known for
    its phases, craters, and influence on Earth's tides, serving as a crucial companion
    since its formation. The Moon orbits Earth at an average distance of 384,400
    kilometers (238,855 miles) and takes about 27.3 days to complete a sidereal orbit.\n\nDue
    to the alignment of the Earth-Moon-Sun system, a full moon cycle, or synodic
    month, lasts about 29.5 days. Tidally locked to Earth, the Moon always shows
    the same side, while the "far side" remains hidden, giving it a consistent face
    in the night sky.
  stats:
  - label: Mass
    value: <b>7.30 x 10<sup>22</sup>kg</b>
  - label: Diameter
    value: <b>3,475 km</b>
  - label: Distance to Planet
    value: <b>384 thousand km</b>
  - label: Orbital Period
    value: <b>27.3 days</b>
  focusDistanceOverride: 0.19
  minFocusDistanceOverride: 0.05
  maxFocusDistanceOverride: 30
